# --- Strapi (опционально) ---
# Если эти переменные НЕ заданы — Next.js работает на статических данных из /data/*.ts.
# Когда задашь NEXT_PUBLIC_STRAPI_URL — страницы начнут тянуть контент из Strapi
# с автоматическим fallback на /data/*.ts в случае ошибок.

# URL Strapi-бэкенда (без слеша в конце)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Read-only API token из Strapi Admin → Settings → API Tokens
# Не обязателен, если ты дал Public-роли права find/findOne (bootstrap делает это автоматически).
STRAPI_API_TOKEN=

# --- Revalidate webhook ---
# Секрет, который надо проверять в /api/revalidate. Сгенерируй командой:
#   openssl rand -hex 32
REVALIDATE_SECRET=

# --- Yandex Maps (по желанию) ---
# Для прод-режима лучше указать. В dev карта работает и без ключа.
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
